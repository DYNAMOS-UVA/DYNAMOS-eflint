// Generated by build-eflint-validation-bundle.sh
// requester=Jorrit
// stewards=VU,UVA

// Layer 1: interface policy
// ─────────────────────────────────────────────────────────────────────────────
// DYNAMOS Policy Enforcer — Layer 1: Interface Policy
// ─────────────────────────────────────────────────────────────────────────────
//
// Stable schema shared between the enforcer codebase and every agreement
// policy (Layer 2).  Declares base types, query facts, the request
// lifecycle (Act + Duty), and their arities.  No derivation rules.
// The agreement policy supplies Holds-when clauses via Extend Fact.
//
// Changes to this file require a codebase release.  The agreement policy can
// be replaced at runtime without touching this layer.
//
// Request-approval input
// ──────────────────────
// The only inputs from a RequestApproval message are:
//   • the requester (user)
//   • an array of data stewards (requested-steward instances)
//
// The policy enforcer fetches each steward's agreement from etcd, checks
// whether the requester has a relation, and discovers the valid archetypes
// and compute providers per steward.  At least one steward must have a
// valid relation for the request to be admissible.
// ─────────────────────────────────────────────────────────────────────────────


// ═══════════════════════════════════════════════════════════════════════════
// Base fact types
// ═══════════════════════════════════════════════════════════════════════════

Fact requester
Fact data-steward
Fact dataset
Fact request-type
Fact archetype
Fact compute-provider

// Marks a data steward as being addressed by the current RequestApproval.
// Populated per request by the Request Context Builder.
Fact requested-steward Identified by data-steward


// ═══════════════════════════════════════════════════════════════════════════
// Query facts — invoked by the DYNAMOS runtime
// ═══════════════════════════════════════════════════════════════════════════

// Overall request admissibility: at least one requested steward must have
// a valid relation with the requester.
Fact permitted-request
  Identified by requester

// Per-steward admissibility: the requester has standing at this steward.
Fact permitted-at-steward
  Identified by requester * data-steward

// Generative queries: enumerate the archetypes and compute providers that
// are valid for a (requester, steward) pair — used by the orchestrator to
// compose the microservice chain.
Fact valid-archetype
  Identified by requester * data-steward * archetype

Fact valid-compute-provider
  Identified by requester * data-steward * compute-provider

// Ongoing decision: evaluated during continuous authorisation for an
// in-flight session that uses a specific archetype at a steward.
// A compute-provider check (valid-compute-provider) is only required
// when the archetype is dataThroughTtp; the runtime handles that separately.
Fact permitted-continuation
  Identified by requester * data-steward * archetype

// ═══════════════════════════════════════════════════════════════════════════
// Request lifecycle
// ═══════════════════════════════════════════════════════════════════════════

// Audit obligation: the data steward must log the processing of a
// requester's data.  Active enforcement is deferred to a future
// Obligation Manager (design decision D5).
Duty obligated-log
  Holder   data-steward
  Claimant requester

// Records that a data request has been accepted for a (requester, steward)
// pair.  Created as an effect of submit-data-request.
Fact data-request
  Identified by requester * data-steward

// The act that transitions a request into an accepted data-request.
// Its enablement conditions reference Layer-1 query facts whose derivation
// rules are supplied by the agreement policy (Layer 2) via Extend Fact.
Act submit-data-request
  Actor requester
  Related to data-steward
  Holds when requested-steward(data-steward)
    && permitted-at-steward(requester, data-steward)
  Creates data-request(requester, data-steward)
  Creates obligated-log(data-steward, requester)

// Layer 2a: shared agreement rules
// ─────────────────────────────────────────────────────────────────────────────
// DYNAMOS Policy Enforcer — Layer 2 (shared): Agreement Rules
// ─────────────────────────────────────────────────────────────────────────────
//
// Loaded after 01_interface_policy.eflint.  Contains:
//
//   (i)   Intermediate fact declarations (agreement + relation structure)
//   (ii)  Extend rules that make the Layer-1 query facts derivable
//
// At runtime the Request Context Builder and PIP populate domain instances,
// agreement data, and request context.  For testing, each scenario file
// bundles everything needed after Layer 1 + Layer 2.
//
// Load order:  01_interface_policy  →  02_agreement_rules  →  scenario_*
// ─────────────────────────────────────────────────────────────────────────────


// ═══════════════════════════════════════════════════════════════════════════
// (i)  Intermediate facts — agreement structure
// ═══════════════════════════════════════════════════════════════════════════

Fact agreement Identified by data-steward

Fact steward-supports-archetype Identified by data-steward * archetype
  Conditioned by agreement(data-steward)

Fact steward-supports-compute-provider Identified by data-steward * compute-provider
  Conditioned by agreement(data-steward)


// ═══════════════════════════════════════════════════════════════════════════
// (i)  Intermediate facts — relation structure
// ═══════════════════════════════════════════════════════════════════════════

Fact has-relation Identified by requester * data-steward
  Conditioned by agreement(data-steward)

Fact relation-allows-request-type Identified by requester * data-steward * request-type
  Conditioned by has-relation(requester, data-steward)

Fact relation-allows-dataset Identified by requester * data-steward * dataset
  Conditioned by has-relation(requester, data-steward)

Fact relation-allows-archetype Identified by requester * data-steward * archetype
  Conditioned by has-relation(requester, data-steward)

Fact relation-allows-compute-provider Identified by requester * data-steward * compute-provider
  Conditioned by has-relation(requester, data-steward)


// ═══════════════════════════════════════════════════════════════════════════
// (ii)  Derivation rules for Layer-1 query facts
// ═══════════════════════════════════════════════════════════════════════════

Extend Fact permitted-at-steward
  Holds when agreement(data-steward)
    && has-relation(requester, data-steward)

Extend Fact permitted-request
  Holds when requested-steward(data-steward)
    && permitted-at-steward(requester, data-steward)

Extend Fact valid-archetype
  Holds when relation-allows-archetype(requester, data-steward, archetype)
    && steward-supports-archetype(data-steward, archetype)

Extend Fact valid-compute-provider
  Holds when relation-allows-compute-provider(requester, data-steward, compute-provider)
    && steward-supports-compute-provider(data-steward, compute-provider)

// Compute-provider validation is only relevant for DataThroughTtp,
// where data is routed through a third party.  For ComputeToData the
// computation travels to the data steward's own infrastructure, so no
// external compute provider is involved.  The runtime checks
// valid-compute-provider separately when the archetype requires it.
Extend Fact permitted-continuation
  Holds when permitted-at-steward(requester, data-steward)
    && valid-archetype(requester, data-steward, archetype)

// Layer 2b: per-steward agreement files
// steward model: VU
// ─────────────────────────────────────────────────────────────────────────────
// DYNAMOS Policy Enforcer — Agreement: VU
// ─────────────────────────────────────────────────────────────────────────────
//
// Layer 2b — Per-steward agreement for VU.
// Stored in etcd at /policyEnforcer/eflintModels/VU.
//
// Requires (loaded by the policy enforcer in this order):
//   1. 01_interface_policy.eflint  (embedded with the enforcer binary)
//   2. 02_agreement_rules.eflint   (etcd /policyEnforcer/eflintRules/shared)
//   3. this file                   (etcd /policyEnforcer/eflintModels/VU)
//   4. Layer-3 request facts       (generated per request)
// ─────────────────────────────────────────────────────────────────────────────

// Type instances referenced by this agreement.
+data-steward("VU").
+archetype("computeToData").
+archetype("dataThroughTtp").
+compute-provider("SURF").
+dataset("wageGap").
+request-type("sqlDataRequest").
+request-type("genericRequest").

+agreement("VU").

// Archetypes supported at the agreement level.
+steward-supports-archetype("VU", "computeToData").
+steward-supports-archetype("VU", "dataThroughTtp").

// Compute providers accepted by VU.
+steward-supports-compute-provider("VU", "SURF").

// ── Relation: Jorrit ────────────────────────────
+has-relation("Jorrit", "VU").
+relation-allows-request-type("Jorrit", "VU", "sqlDataRequest").
+relation-allows-request-type("Jorrit", "VU", "genericRequest").
+relation-allows-dataset("Jorrit", "VU", "wageGap").
+relation-allows-archetype("Jorrit", "VU", "computeToData").
+relation-allows-archetype("Jorrit", "VU", "dataThroughTtp").
+relation-allows-compute-provider("Jorrit", "VU", "SURF").

// steward model: UVA
// ─────────────────────────────────────────────────────────────────────────────
// DYNAMOS Policy Enforcer — Agreement: UVA
// ─────────────────────────────────────────────────────────────────────────────
//
// Layer 2b — Per-steward agreement for UVA.
// Stored in etcd at /policyEnforcer/eflintModels/UVA.
//
// Requires (loaded by the policy enforcer in this order):
//   1. 01_interface_policy.eflint  (embedded with the enforcer binary)
//   2. 02_agreement_rules.eflint   (etcd /policyEnforcer/eflintRules/shared)
//   3. this file                   (etcd /policyEnforcer/eflintModels/UVA)
//   4. Layer-3 request facts       (generated per request)
// ─────────────────────────────────────────────────────────────────────────────

// Type instances referenced by this agreement.
+data-steward("UVA").
+archetype("computeToData").
+archetype("dataThroughTtp").
+archetype("reproducableScience").
+compute-provider("SURF").
+dataset("wageGap").
+request-type("sqlDataRequest").
+request-type("genericRequest").

+agreement("UVA").

// Archetypes supported at the agreement level.
+steward-supports-archetype("UVA", "computeToData").
+steward-supports-archetype("UVA", "dataThroughTtp").
+steward-supports-archetype("UVA", "reproducableScience").

// Compute providers accepted by UVA.
+steward-supports-compute-provider("UVA", "SURF").

// ── Relation: Jorrit ────────────────────────────
+has-relation("Jorrit", "UVA").
+relation-allows-request-type("Jorrit", "UVA", "sqlDataRequest").
+relation-allows-request-type("Jorrit", "UVA", "genericRequest").
+relation-allows-dataset("Jorrit", "UVA", "wageGap").
+relation-allows-archetype("Jorrit", "UVA", "computeToData").
+relation-allows-archetype("Jorrit", "UVA", "dataThroughTtp").
+relation-allows-compute-provider("Jorrit", "UVA", "SURF").

// Layer 3: request facts
+requester("Jorrit").
+requested-steward("VU").
+requested-steward("UVA").

// Queries used in EvaluateRequestApproval
?Holds(permitted-request("Jorrit")).
?Holds(permitted-at-steward("Jorrit", "VU")).
?-archetype When valid-archetype("Jorrit", "VU", archetype).
?-compute-provider When valid-compute-provider("Jorrit", "VU", compute-provider).
?Holds(permitted-at-steward("Jorrit", "UVA")).
?-archetype When valid-archetype("Jorrit", "UVA", archetype).
?-compute-provider When valid-compute-provider("Jorrit", "UVA", compute-provider).

// Acts used in EvaluateRequestApproval
// Run submit-data-request only for stewards where permitted-at-steward holds.
// submit-data-request("Jorrit", "VU").
// submit-data-request("Jorrit", "UVA").
